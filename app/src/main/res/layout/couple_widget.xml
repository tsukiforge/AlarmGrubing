<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <!-- NO COUPLE STATE -->
    <LinearLayout
        android:id="@+id/no_couple_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_bg"
        android:padding="12dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💕 Couple Sync Mode"
            android:textColor="#C2185B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Belum ada pasangan aktif.\nBuka list anggota grup, pilih teman, lalu tap 'Pair'!"
            android:textColor="#5D4037"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- ACTIVE COUPLE STATE -->
    <LinearLayout
        android:id="@+id/couple_active_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FAFAFA"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Header line -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💕 Bel Pasangan (Couple)"
                android:textColor="#D81B60"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_alignParentLeft="true" />

            <TextView
                android:id="@+id/sync_bonus_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Sync Bonus (+15) Aktif!"
                android:textColor="#E65100"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_alignParentRight="true"
                android:visibility="gone" />
        </RelativeLayout>

        <!-- Dynamic Content: 2 Columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Partner A Column (Self/Initer) -->
            <LinearLayout
                android:id="@+id/partner_a_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/partner_blue_bg"
                android:padding="6dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/partner_a_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Partner A"
                    android:textColor="#0d47a1"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/partner_a_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💤 Tidur"
                    android:textColor="#37474f"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/partner_a_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 100%"
                    android:textColor="#37474f"
                    android:textSize="10sp"
                    android:layout_marginTop="1dp" />

                <TextView
                    android:id="@+id/partner_a_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Poin: 0 | Streak: 0 🔥"
                    android:textColor="#455a64"
                    android:textSize="9sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Partner B Column (Target) -->
            <LinearLayout
                android:id="@+id/partner_b_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/partner_pink_bg"
                android:padding="6dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/partner_b_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Partner B"
                    android:textColor="#880e4f"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/partner_b_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💤 Tidur"
                    android:textColor="#37474f"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/partner_b_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 100%"
                    android:textColor="#37474f"
                    android:textSize="10sp"
                    android:layout_marginTop="1dp" />

                <TextView
                    android:id="@+id/partner_b_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Poin: 0 | Streak: 0 🔥"
                    android:textColor="#455a64"
                    android:textSize="9sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tap to Toggle status button on Widget bottom -->
        <Button
            android:id="@+id/widget_toggle_awake"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/holo_green_dark"
            android:text="SAYA SUDAH BANGUN ☀️"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
